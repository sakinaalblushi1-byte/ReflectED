{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "xp": { "type": "integer", "description": "Total experience points earned." },
        "level": { "type": "integer", "description": "Current level of the trainee." },
        "streak": { "type": "integer", "description": "Current daily reflection streak." },
        "badges": { "type": "array", "items": { "type": "string" }, "description": "List of earned badge IDs." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Reflection": {
      "title": "Reflection",
      "description": "A teacher's reflection on a lesson.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who created the reflection." },
        "lessonType": { "type": "string", "description": "The type of lesson (e.g., PPP, TBLT)." },
        "skillFocus": { "type": "array", "items": { "type": "string" }, "description": "Skills focused on in the lesson." },
        "week": { "type": "integer", "description": "The week number of the training." },
        "description": { "type": "string", "description": "Description of the lesson." },
        "feelings": { "type": "string", "description": "How the teacher felt during the lesson." },
        "evaluation": { "type": "string", "description": "Evaluation of the lesson." },
        "analysis": { "type": "string", "description": "Analysis of the lesson." },
        "conclusion": { "type": "string", "description": "Conclusion of the reflection." },
        "actionPlan": { "type": "string", "description": "Action plan for future lessons." },
        "aiFeedback": { "type": "object", "description": "AI-generated feedback and analysis." },
        "xpEarned": { "type": "integer", "description": "XP earned for this reflection." },
        "badgesEarned": { "type": "array", "items": { "type": "string" }, "description": "Badges earned for this reflection." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the reflection was created." }
      },
      "required": ["userId", "lessonType", "description", "createdAt"]
    },
    "PeerFeedback": {
      "title": "Peer Feedback",
      "description": "Feedback from peers or supervisors on a reflection.",
      "type": "object",
      "properties": {
        "reflectionId": { "type": "string", "description": "The ID of the reflection being commented on." },
        "authorId": { "type": "string", "description": "The ID of the person giving feedback." },
        "authorName": { "type": "string", "description": "The name of the person giving feedback." },
        "content": { "type": "string", "description": "The feedback content." },
        "rating": { "type": "integer", "description": "Rating given (1-5)." },
        "isSupervisor": { "type": "boolean", "description": "Whether the feedback is from a supervisor." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the feedback was created." }
      },
      "required": ["reflectionId", "authorId", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/reflections/{reflectionId}": {
      "schema": "Reflection",
      "description": "Collection of lesson reflections."
    },
    "/peerFeedback/{feedbackId}": {
      "schema": "PeerFeedback",
      "description": "Collection of peer and supervisor feedback."
    }
  }
}
